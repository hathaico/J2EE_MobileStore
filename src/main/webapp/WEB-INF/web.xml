<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Mobile Store Management System</display-name>
    <description>J2EE Mobile Store Application</description>

    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Encoding Filter -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.mobilestore.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Authentication Filter -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.mobilestore.filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- Application Context Listener -->
    <listener>
        <listener-class>com.mobilestore.listener.AppContextListener</listener-class>
    </listener>

    <!-- Session Timeout (30 minutes) -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error/500.jsp</location>
    </error-page>

    <!-- Database Configuration -->

    <!-- REST API Servlet: Product -->
    <!-- REST API Servlet: Product Review -->
    <servlet>
        <servlet-name>ProductReviewApiServlet</servlet-name>
        <servlet-class>com.mobilestore.api.ProductReviewApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductReviewApiServlet</servlet-name>
        <url-pattern>/api/product-review</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProductApiServlet</servlet-name>
        <servlet-class>com.mobilestore.api.ProductApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductApiServlet</servlet-name>
        <url-pattern>/api/products/*</url-pattern>
    </servlet-mapping>

    <!-- REST API Servlet: User -->
    <servlet>
        <servlet-name>UserApiServlet</servlet-name>
        <servlet-class>com.mobilestore.api.UserApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserApiServlet</servlet-name>
        <url-pattern>/api/users/*</url-pattern>
    </servlet-mapping>

    <!-- REST API Servlet: Auth -->
    <servlet>
        <servlet-name>AuthApiServlet</servlet-name>
        <servlet-class>com.mobilestore.api.AuthApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthApiServlet</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>


        <!-- REST API Servlet: Voucher -->
        <servlet>
            <servlet-name>VoucherApiServlet</servlet-name>
            <servlet-class>com.mobilestore.api.VoucherApiServlet</servlet-class>
        </servlet>
        <servlet-mapping>
            <servlet-name>VoucherApiServlet</servlet-name>
            <url-pattern>/api/voucher</url-pattern>
        </servlet-mapping>

    <context-param>
        <param-name>dbUrl</param-name>
        <param-value>jdbc:mysql://localhost:3306/mobilestore_db</param-value>
    </context-param>
    <context-param>
        <param-name>dbUser</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>dbPassword</param-name>
        <param-value>password</param-value>
    </context-param>

    <!-- SVG MIME Type -->
    <mime-mapping>
        <extension>svg</extension>
        <mime-type>image/svg+xml</mime-type>
    </mime-mapping>

</web-app>
